	month = sep,
	title = {Non-Abelian {{Gauge Fields}} from {{Defects}} in \{\vphantom\}{{Spin-Networks}}\vphantom\{\}},
	year = {2013}}

@article{Yadav2018M-theory,
	abstract = {Using the pull-back of the perturbed type IIA metric corresponding to the perturbation of arXiv:hep-th/1306.4339's M-theory uplift of arXiv:hep-th/0902.1540's UV-complete top-down type IIB holographic dual of large-\$N\$ thermal QCD, at finite coupling, we obtain the interaction Lagrangian corresponding to exotic scalar glueball(\$G\_E\$)-\${\textbackslash}rho/{\textbackslash}pi\$-meson interaction, linear in the exotic scalar glueball and up to quartic order in the \${\textbackslash}pi\$ mesons. In the Lagrangian, the coupling constants are determined as (radial integrals of) arXiv:hep-th/1306.4339's M-theory uplift's metric components and six radial functions appearing in the M-theory metric perturbations. Assuming \$M\_G{$>$}2M\_{\textbackslash}rho\$, we then compute \${\textbackslash}rho{\textbackslash}rightarrow2{\textbackslash}pi, G\_E{\textbackslash}rightarrow2{\textbackslash}pi, 2{\textbackslash}rho, {\textbackslash}rho+2{\textbackslash}pi\$ decay widths as well as the direct and indirect (mediated via \${\textbackslash}rho\$ mesons) \$G\_E{\textbackslash}rightarrow4{\textbackslash}pi\$ decays. For numerics, we choose \$f0[1710]\$ and compare with previous calculations. We emphasize that our results can be made to match PDG data (and improvements thereof) exactly by appropriate tuning of some constants of integration appearing in the solution of the M-theory metric perturbations and the \${\textbackslash}rho\$ and \${\textbackslash}pi\$ meson radial profile functions - a flexibility that our calculations permits.},
	archiveprefix = {arXiv},
	author = {Yadav, Vikas and Misra, Aalok},
