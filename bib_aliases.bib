	doi = {10.1007/JHEP09(2018)133},
	eprint = {1808.01182},
	file = {/Users/deepak/ownCloud/root/research/mendeley/Yadav;Misra_M-theory exotic scalar glueball decays to mesons at finite coupling_2018.pdf},
	issn = {1029-8479},
	journal = {Journal of High Energy Physics},
	keywords = {_tablet},
	month = sep,
	number = {9},
	pages = {133},
	title = {M-Theory Exotic Scalar Glueball Decays to Mesons at Finite Coupling},
	urldate = {2018-12-16},
	volume = {2018},
	year = {2018},
